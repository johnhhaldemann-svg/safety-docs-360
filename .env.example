# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.

# --- Supabase (your project) ---
# Use one Supabase project for local dev and Vercel: paste the same values in Vercel → Environment Variables.
# Dashboard: https://supabase.com/dashboard → your project → Project Settings → API
#   - Project URL  → NEXT_PUBLIC_SUPABASE_URL
#   - anon public  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - service_role → SUPABASE_SERVICE_ROLE_KEY (keep secret; never expose as NEXT_PUBLIC_*)
# Apply migrations: `npm run db:scaffold-url` once to append DATABASE_URL, set your password, then `npm run db:push:env`;
# or `npx supabase db push` when linked to the project;
# or paste SQL from supabase/migrations in Dashboard → SQL.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# If you already created a Vercel env with a typo, the app still reads: SUPABASE_SERIVCE_ROLE_KEY
#
# Local CLI migrations from Windows (IPv4): Dashboard → Connect → Session pooler → URI (port 5432; host may be aws-0- or aws-1-).
# Or run `npm run db:try-pooler` after setting DATABASE_URL with postgres.<ref>:password@any.pooler (script finds working host).
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres
# (Use the exact string from the dashboard; do not commit real passwords.)

# Optional: bulk SOR import into `company_sor_records`
#   node scripts/import-sor-xlsx.mjs --list-companies
#   node scripts/import-sor-xlsx.mjs "C:/path/to/SOR Fixed.xlsx"
# SOR_IMPORT_COMPANY_ID=<uuid from Table Editor → public.companies → id — must be real or insert fails with company_sor_records_company_id_fkey>
# SOR_IMPORT_PROJECT=Imported workbook
# SOR_IMPORT_LOCATION=Field
# SOR_IMPORT_DRY_RUN=1   # parse-only preview; remove or set 0 for real insert

# Optional: platform admin emails (comma-separated), matches lib/admin.ts / NEXT_PUBLIC_ADMIN_EMAILS
# NEXT_PUBLIC_ADMIN_EMAILS=you@company.com

# Optional: canonical public URL for invite links and redirects (production)
# NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Optional: shown on /privacy for privacy and data inquiries (production)
# NEXT_PUBLIC_SUPPORT_EMAIL=privacy@your-domain.com

# Vercel sets VERCEL_URL in deployments; NEXT_PUBLIC_VERCEL_URL is only needed in special cases.

# CSEP test user — seeds Auth + company in YOUR Supabase (same URL + service role as above). Run once: `npm run seed:csep-test`
# Default login: csep-test@example.com / CsepLocalTest2026! (override below if you want)
# CSEP_TEST_EMAIL=csep-test@example.com
# CSEP_TEST_PASSWORD=CsepLocalTest2026!
# CSEP_TEST_ROLE=company_admin

# Playwright E2E (optional — enables authenticated suites + global setup storage state)
# E2E_USER_EMAIL=test@example.com
# E2E_USER_PASSWORD=your_test_password
# GitHub Actions "playwright-full" on main also needs these as repo secrets (same names with E2E_ prefix for URL/anon):
# E2E_NEXT_PUBLIC_SUPABASE_URL / E2E_NEXT_PUBLIC_SUPABASE_ANON_KEY — all four must be set for that job to run.
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_SKIP_WEBSERVER=1   # when you already ran `npm run dev` manually
# E2E_ATTACH_DIAGNOSTICS_ALWAYS=1   # attach console/network to report even on pass
# test-results/ and playwright-report/ are gitignored — they can include credentials from failure snapshots.

# Optional: company invite “from” address if you send email via Resend etc. (see lib/inviteEmail.ts)
# RESEND_FROM_EMAIL=onboarding@your-domain.com

# Optional: Stripe (billing invoices — Checkout links + webhooks). Dashboard: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # Signing secret from Developers → Webhooks → your endpoint
# Public URL for Checkout redirects (production):
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- OpenAI (recommended for production) ---
# Used for: Injury Weather insights, Streamlit forecaster (optional), company memory embeddings, /api/company/ai/assist.
# OPENAI_API_KEY=sk-...
# Optional: Vercel AI Gateway — use your gateway key (vck_…) as OPENAI_API_KEY and set the base URL (models use provider/model automatically when this host is set):
# OPENAI_BASE_URL=https://ai-gateway.vercel.sh/v1
#
# Production check (Vercel): Project → Settings → Environment Variables → ensure OPENAI_API_KEY is set for Production
# (and Preview if you test assist there). Redeploy after adding or changing the key. Without it, company assist may error
# and memory retrieval falls back to keyword search only (no embeddings on new/edited memory rows).
#
# Optional: model for Streamlit forecaster briefings (default gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini
#
# Company assist only — optional override (default gpt-4o-mini). See lib/companyMemory/assist.ts.
# COMPANY_AI_MODEL=gpt-4o-mini
# Optional: model for Risk Memory “AI + rules” recommendations (defaults to COMPANY_AI_MODEL or gpt-4o-mini). See lib/riskMemory/llmRecommendations.ts.
# RISK_MEMORY_LLM_MODEL=gpt-4o-mini

# --- Injury Weather (optional AI layers; trends/forecasts from data are deterministic — see lib/injuryWeather/service.ts, riskModel.ts) ---
# Narrative AI insights and extras need OPENAI_API_KEY (same as above). Without a key, the API uses deterministic fallback text and aiForecastMeta may report no_api_key (see app/api/superadmin/injury-weather/route.ts).
# INJURY_WEATHER_AI_FORECAST_OVERRIDE=1   # request structured forecast patches from the model and merge when valid — lib/injuryWeather/ai.ts (isInjuryWeatherAiForecastOverrideEnabled)
# INJURY_WEATHER_SPARSE_WEB_RESEARCH=0    # set to 0 to disable the web-search supplement entirely (default: enabled) — lib/injuryWeather/sparseDataWebResearch.ts
# INJURY_WEATHER_WEB_RESEARCH_MODEL=gpt-4o   # optional; default gpt-4o — lib/injuryWeather/sparseDataWebResearch.ts

# Optional: Superadmin OSHA IPA lab (/superadmin/osha-ipa-lab) — embed/link to Streamlit app (run separately).
# Example local: npm run streamlit:osha:install → npm run streamlit:osha:demo-data (optional) → npm run streamlit:osha
# Default http://127.0.0.1:8501 (see .streamlit/config.toml)
# NEXT_PUBLIC_STREAMLIT_OSHA_URL=http://127.0.0.1:8501

# --- Vercel ---
# Deploy checklist and troubleshooting: docs/production-deployment.md (Vercel section + build-failure table).
# Enable Cron in Vercel project (vercel.json schedules /api/cron/injury-weather-refresh).
# Required for protected cron endpoints — set CRON_SECRET in Vercel Production + Preview if crons run there.
# CRON_SECRET=replace_with_long_random_secret
# Optional: cap companies processed per run by /api/cron/risk-memory-rollup (default 300, max 2000).
# RISK_MEMORY_CRON_MAX_COMPANIES=300
