{
  "expo": {
    "name": "SafePredict Field",
    "slug": "safety360docs",
    "version": "1.0.0",
    "description": "Field safety operations companion for SafePredict company users.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "safepredictfield",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.safety360docs.field",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "SafePredict Field uses the camera to attach field evidence photos to JSAs, audits, and field reports.",
        "NSPhotoLibraryUsageDescription": "SafePredict Field can attach existing photos as evidence for field safety records.",
        "NSLocationWhenInUseUsageDescription": "SafePredict Field may use location to support jobsite context for field safety records."
      }
    },
    "android": {
      "package": "com.safety360docs.field",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker",
      "expo-location"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "66993d47-cdaa-44fc-8553-daa634b632a9"
      }
    },
    "owner": "safety360docs"
  }
}
